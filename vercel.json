{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": "other",
  "nodejs": "20.x",
  "functions": {
    "api/[...slug].js": {
      "runtime": "nodejs20.x",
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/[...slug]"
    }
  ]
}

